{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "meta": {
    "name": "Fujin Design Tokens",
    "version": "0.1.0",
    "platform": "web+native",
    "description": "Shared token contract for Mantine (web) and React Native (native) UI projects"
  },

  "color": {
    "palette": {
      "slate": {
        "0": "#f8fafc",
        "1": "#f1f5f9",
        "2": "#e2e8f0",
        "3": "#cbd5e1",
        "4": "#94a3b8",
        "5": "#64748b",
        "6": "#475569",
        "7": "#334155",
        "8": "#1e293b",
        "9": "#0f172a"
      }
    },
    "semantic": {
      "background": {
        "base":     "#0f172a",
        "surface":  "#1e293b",
        "elevated": "#334155",
        "overlay":  "#475569"
      },
      "text": {
        "primary":   "#f8fafc",
        "secondary": "#cbd5e1",
        "muted":     "#94a3b8",
        "inverse":   "#0f172a"
      },
      "border": {
        "subtle":  "#334155",
        "default": "#475569",
        "strong":  "#94a3b8"
      },
      "interactive": {
        "default":  "#64748b",
        "hover":    "#94a3b8",
        "active":   "#cbd5e1",
        "disabled": "#334155"
      },
      "status": {
        "danger":  "#f87171",
        "warning": "#fbbf24",
        "success": "#4ade80",
        "info":    "#60a5fa"
      }
    },

    "themes": {
      "dark": {
        "background": {
          "base":     "#0f172a",
          "surface":  "#1e293b",
          "elevated": "#334155",
          "overlay":  "#475569"
        },
        "text": {
          "primary":   "#f8fafc",
          "secondary": "#cbd5e1",
          "muted":     "#94a3b8",
          "inverse":   "#0f172a"
        },
        "border": {
          "subtle":  "#334155",
          "default": "#475569",
          "strong":  "#94a3b8"
        },
        "interactive": {
          "default":  "#64748b",
          "hover":    "#94a3b8",
          "active":   "#cbd5e1",
          "disabled": "#334155"
        },
        "status": {
          "danger":  "#f87171",
          "warning": "#fbbf24",
          "success": "#4ade80",
          "info":    "#60a5fa"
        },
        "shadow": {
          "sm": "0 1px 2px rgba(0, 0, 0, 0.4)",
          "md": "0 2px 4px rgba(0, 0, 0, 0.5)",
          "lg": "0 4px 8px rgba(0, 0, 0, 0.6)"
        }
      },

      "light": {
        "background": {
          "base":     "#f1f5f9",
          "surface":  "#f8fafc",
          "elevated": "#ffffff",
          "overlay":  "#e2e8f0"
        },
        "text": {
          "primary":   "#0f172a",
          "secondary": "#334155",
          "muted":     "#64748b",
          "inverse":   "#f8fafc"
        },
        "border": {
          "subtle":  "#e2e8f0",
          "default": "#cbd5e1",
          "strong":  "#64748b"
        },
        "interactive": {
          "default":  "#475569",
          "hover":    "#334155",
          "active":   "#1e293b",
          "disabled": "#e2e8f0"
        },
        "status": {
          "danger":  "#f87171",
          "warning": "#fbbf24",
          "success": "#4ade80",
          "info":    "#60a5fa"
        },
        "shadow": {
          "sm": "0 1px 2px rgba(0, 0, 0, 0.08)",
          "md": "0 2px 4px rgba(0, 0, 0, 0.12)",
          "lg": "0 4px 8px rgba(0, 0, 0, 0.16)"
        }
      }
    }
  },

  "spacing": {
    "base": 4,
    "scale": {
      "xxs": 2,
      "xs":  10,
      "sm":  12,
      "md":  16,
      "lg":  20,
      "xl":  24,
      "xxl": 32
    }
  },

  "typography": {
    "fontFamily": {
      "base": "\"Verdana\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif",
      "mono": "\"JetBrains Mono\", \"Fira Code\", \"Cascadia Code\", Menlo, Consolas, monospace"
    },
    "fontSize": {
      "xs":  10,
      "sm":  12,
      "md":  14,
      "lg":  16,
      "xl":  20,
      "xxl": 24,
      "h1":  32,
      "h2":  24,
      "h3":  20,
      "h4":  16,
      "h5":  14,
      "h6":  12
    },
    "fontWeight": {
      "regular":  400,
      "medium":   500,
      "semibold": 600,
      "bold":     700
    },
    "lineHeight": {
      "tight":   1.2,
      "base":    1.5,
      "relaxed": 1.75
    },
    "letterSpacing": {
      "tight":   "-0.02em",
      "base":    "0em",
      "wide":    "0.05em",
      "widest":  "0.1em"
    }
  },

  "radius": {
    "xs":      0,
    "sm":      0,
    "md":      0,
    "lg":      0,
    "xl":      0,
    "default": 0
  },

  "opacity": {
    "disabled": 0.5,
    "loading":  0.7
  },

  "shadow": {
    "xs": "none",
    "sm": "0 1px 2px rgba(0, 0, 0, 0.4)",
    "md": "0 2px 4px rgba(0, 0, 0, 0.5)",
    "lg": "0 4px 8px rgba(0, 0, 0, 0.6)",
    "xl": "0 8px 16px rgba(0, 0, 0, 0.7)"
  },

  "breakpoints": {
    "xs": 576,
    "sm": 768,
    "md": 992,
    "lg": 1200,
    "xl": 1408
  },

  "transition": {
    "duration": {
      "fast": "100ms",
      "base": "150ms",
      "slow": "250ms"
    },
    "easing": {
      "default": "ease",
      "in":      "ease-in",
      "out":     "ease-out",
      "inOut":   "ease-in-out"
    }
  }
}
